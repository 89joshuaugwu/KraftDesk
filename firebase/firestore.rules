rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.role == "designer"; // force default role on signup
      allow update: if request.auth != null && (
        request.auth.uid == uid && request.resource.data.role == resource.data.role // self-update, can't change own role
        || getRole() == "admin" // admin can change any user's role
      );
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && getRole() == "admin";
    }

    match /posters/{posterId} {
      // Gating happens at the application layer (watermark logic + the
      // role-gated /api/posters/[id]/download route), not read access.
      // See CONTEXT.md Section 5 and README.md "Security model" for the
      // reasoning and the exact place this is enforced in the app.
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploadedBy;

      // Updates:
      // - reviewers and admins may perform review transitions (approved/changes_requested/rejected)
      //   but may NOT set status to "published" directly — publish must go through
      //   /api/posters/[id]/status so the clean (un-watermarked) previewUrl gets
      //   recomputed atomically with the status change. Skipping the server route
      //   leaves previewUrl pointing at the watermarked transform.
      // - uploader (owner) may update their own poster but must NOT set status to
      //   "published" from the client either — same reasoning applies to the
      //   uploader-publishes-after-approval flow.
      allow update: if request.auth != null && (
        (
          getRole() in ["reviewer", "admin"]
          && (
            request.resource.data.status == resource.data.status
            || request.resource.data.status in ["approved", "changes_requested", "rejected"]
          )
        )
        || (
          request.auth.uid == resource.data.uploadedBy
          && (
            // either status unchanged, or status set to a non-published valid value
            request.resource.data.status == resource.data.status
            || request.resource.data.status in ["draft", "pending", "changes_requested"]
          )
        )
      );

      match /versions/{versionNumber} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
    }

    match /notifications/{uid}/items/{notifId} {
      allow read, update: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null; // written by server actions on behalf of other users
    }
  }
}
